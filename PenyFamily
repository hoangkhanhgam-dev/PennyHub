		floatBV.MaxForce = Vector3.new(1e9, 1e9, 1e9)
		floatBV.Velocity = Vector3.new(0, 0, 0)
		floatBV.Parent = hrp
	end

	if not floatBG then
		floatBG = Instance.new("BodyGyro")
		floatBG.Name = "Penny_FloatGyro"
		floatBG.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
		floatBG.P = 50000
		floatBG.CFrame = hrp.CFrame
		floatBG.Parent = hrp
	end

