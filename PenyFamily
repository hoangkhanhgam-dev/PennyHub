local function forceStopFloat()
	-- Chỉ reset đúng 1 lần khi vừa tắt auto.
	-- Nếu spam ChangeState mỗi frame thì nhân vật sẽ bị khựng, rơi chậm, nhảy không cao.
	local needReset = floatActive or floatBV ~= nil or floatBG ~= nil

	if floatBV then
		floatBV:Destroy()
		floatBV = nil
	end

	if floatBG then
		floatBG:Destroy()
		floatBG = nil
	end

	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")

	-- Dọn đúng BodyMover của hub, không quét nhầm toàn bộ BodyMover khác của game.
	if hrp then
		for _, v in ipairs(hrp:GetChildren()) do
			if v.Name == "Penny_FloatVelocity" or v.Name == "Penny_FloatGyro" then
				needReset = true
				v:Destroy()
			end
		end

		hrp.Anchored = false
		-- Chỉ xóa lực bay 1 lần, không ép vận tốc liên tục để tránh rơi chậm/di chuyển khựng.
		if needReset then
			hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
			hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
		end
	end

	if hum and needReset then
		hum.PlatformStand = false
		hum.Sit = false
		hum.AutoRotate = true
		hum:ChangeState(Enum.HumanoidStateType.GettingUp)

		task.delay(0.15, function()
			if hum and hum.Parent then
				hum.PlatformStand = false
				hum.Sit = false
				hum.AutoRotate = true
				hum:ChangeState(Enum.HumanoidStateType.Running)
			end
		end)
	end

	floatActive = false
end


--// DROP PIN + NOCLIP
-- Giữ nhân vật đứng yên đúng điểm drop, hạn chế bị player khác đẩy ra chỗ quái.
local dropPinConn = nil
local dropNoClipBackup = {}

local function setDropNoClip(enabled)
	local char = player.Character
	if not char then return end

	for _, part in ipairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			if enabled then
				if dropNoClipBackup[part] == nil then
					dropNoClipBackup[part] = part.CanCollide
				end
				part.CanCollide = false
			else
				if dropNoClipBackup[part] ~= nil then
					part.CanCollide = dropNoClipBackup[part]
				end
			end
		end
	end

	if not enabled then
		dropNoClipBackup = {}
	end
end

local function stopDropPin()
	if dropPinConn then
		dropPinConn:Disconnect()
		dropPinConn = nil
	end

	setDropNoClip(false)
end

local function startDropPin(pinPos, token)
	if not Config.DropPinEnabled then return end

	stopDropPin()

	local char, hrp, hum = getChar()
	if not char or not hrp or not hum then return end

	if Config.DropNoClip then
		setDropNoClip(true)
	end

	hum.PlatformStand = true
	hum.Sit = false
	hum.AutoRotate = false

	if floatBV then
		floatBV.Velocity = Vector3.new(0, 0, 0)
		floatBV.MaxForce = Vector3.new(1e9, 1e9, 1e9)
	end

	if floatBG then
		floatBG.CFrame = CFrame.new(pinPos)
	end

	dropPinConn = RunService.Heartbeat:Connect(function()
		if token ~= actionToken or not Config.AutoDropSam or not isCharacterReady() then
			stopDropPin()
			return
		end

		local c = player.Character
		local root = c and c:FindFirstChild("HumanoidRootPart")
		local humanoid = c and c:FindFirstChildOfClass("Humanoid")
		if not root or not humanoid then return end

		if Config.DropNoClip then
			setDropNoClip(true)
		end

		humanoid.PlatformStand = true
		humanoid.Sit = false
		humanoid.AutoRotate = false

		root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
		root.CFrame = CFrame.new(pinPos)

		if floatBV then
			floatBV.Velocity = Vector3.new(0, 0, 0)
		end

		if floatBG then
			floatBG.CFrame = root.CFrame
		end
	end)
end


local function stopFloatIfIdle()
