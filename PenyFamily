function refreshConfigList()
	for _, c in ipairs(configList:GetChildren()) do
		if c:IsA("TextButton") then
			c:Destroy()
		end
	end

	configButtons = {}

	for _, name in ipairs(listConfigNames()) do
		local b = Instance.new("TextButton")
		b.Parent = configList
		b.Size = UDim2.new(1, -4, 0, 30)
		b.Text = name
		b.BackgroundColor3 = (Config.SelectedConfig == name) and Color3.fromRGB(110, 125, 155) or Color3.fromRGB(20, 25, 35)
		b.TextColor3 = Color3.fromRGB(235, 240, 255)
		b.Font = Enum.Font.GothamBold
		b.TextSize = 12
		b.ZIndex = 7
		Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)

		b.MouseButton1Click:Connect(function()
			Config.SelectedConfig = name
			Config.LastConfigName = name
			configNameBox.Text = name
			saveIndexConfig()
			refreshConfigList()
			refreshSelectedLabel()
		end)

		configButtons[name] = b
	end

	refreshSelectedLabel()
end

