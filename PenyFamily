--// AUTO USE DRINK BY AMOUNT
-- Uống Cider / Lemonade / Juice / Smoothie theo số lượng.
-- Bản nhanh: đánh dấu tool đã uống để không click lặp lại tool cũ, không cần đợi tool biến mất.
local usedDrinkCache = {}

local function getUseDrinkDelay()
	local n = tonumber(Config.UseDrinkDelay) or 0.15
	return math.clamp(n, 0.03, 3)
end

local function useDrinkToolFast(tool)
	if not tool or not tool.Parent then return false end
	if usedDrinkCache[tool] then return false end
	if not isCharacterReady() then return false end

	local char, hrp, hum = getChar()
	if not char or not hum then return false end

	-- Đánh dấu trước để vòng sau không quét lại đúng ly đang uống.
	usedDrinkCache[tool] = true

	if tool.Parent ~= char then
		hum:EquipTool(tool)
		task.wait(0.05)
	end

	if not tool or not tool.Parent then return false end

	pcall(function()
		tool:Activate()
	end)

	return true
end

local function useDrinkByAmount(typeName, amount)
	if not isCharacterReady() then return 0 end

	amount = math.floor(tonumber(amount) or 0)
	if amount <= 0 then return 0 end

	local used = 0

	while Config.AutoUseDrinkAmount and used < amount and isCharacterReady() do
		local tools = getTools(typeName)
		if #tools == 0 then break end

		local picked = nil

		for _, tool in ipairs(tools) do
			if tool and tool.Parent and not usedDrinkCache[tool] then
				picked = tool
				break
			end
		end

		if not picked then
			break
		end

		local ok = useDrinkToolFast(picked)

		if ok then
			used += 1
		else
			break
		end

		task.wait(getUseDrinkDelay())
	end

	return used
end

local function doUseDrinkAmountOnce()
	if not Config.AutoUseDrinkAmount then return end
	if not isCharacterReady() then return end

	local ciderNeed = getDropAmountValue("UseCiderAmount")
	local lemonadeNeed = getDropAmountValue("UseLemonadeAmount")
	local juiceNeed = getDropAmountValue("UseJuiceAmount")
	local smoothieNeed = getDropAmountValue("UseSmoothieAmount")

	if ciderNeed > 0 then
		print("[PennyHub] Use Cider:", ciderNeed)
		useDrinkByAmount("Cider", ciderNeed)
	end

	if lemonadeNeed > 0 then
		print("[PennyHub] Use Lemonade:", lemonadeNeed)
		useDrinkByAmount("Lemonade", lemonadeNeed)
	end

	if juiceNeed > 0 then
		print("[PennyHub] Use Juice:", juiceNeed)
		useDrinkByAmount("Juice", juiceNeed)
	end

	if smoothieNeed > 0 then
		print("[PennyHub] Use Smoothie:", smoothieNeed)
		useDrinkByAmount("Smoothie", smoothieNeed)
	end
end

local function runAutoUseDrinkAmount()
	if autoUseDrinkRunning then return end
	autoUseDrinkRunning = true

	-- Reset cache mỗi lần bật để lần chạy mới vẫn dùng được item mới.
	usedDrinkCache = {}

	task.spawn(function()
