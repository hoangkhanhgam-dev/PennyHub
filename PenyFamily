--// FILE SYSTEM
local function fsReady()
	return isfolder and makefolder and isfile and writefile and readfile and listfiles
end

local function ensureWorkspace()
	if not fsReady() then
		warn("[PennyHub] Executor không hỗ trợ file system đầy đủ.")
		return false
	end

	if not isfolder(WORKSPACE_FOLDER) then
		makefolder(WORKSPACE_FOLDER)
	end

	if not isfolder(CONFIG_FOLDER) then
		makefolder(CONFIG_FOLDER)
	end

	if not isfile(CONFIG_INDEX_FILE) then
		writefile(CONFIG_INDEX_FILE, HttpService:JSONEncode(Config))
	end

	return true
end

local function safeEncode(tbl)
	local ok, result = pcall(function()
		return HttpService:JSONEncode(tbl)
	end)
	return ok and result or "{}"
end

local function safeDecode(raw)
	local ok, result = pcall(function()
		return HttpService:JSONDecode(raw)
	end)
	if ok and type(result) == "table" then
		return result
	end
	return nil
end

local function applyTableToConfig(data)
	if type(data) ~= "table" then return end
	for k, v in pairs(data) do
		if Config[k] ~= nil then
			Config[k] = v
		end
	end
end

local function saveIndexConfig()
	if not ensureWorkspace() then return false end
	writefile(CONFIG_INDEX_FILE, safeEncode(Config))
	return true
end

local function loadIndexConfig()
	if not ensureWorkspace() then return false end
	if not isfile(CONFIG_INDEX_FILE) then return false end

	local data = safeDecode(readfile(CONFIG_INDEX_FILE))
	if not data then return false end

	applyTableToConfig(data)
	return true
end

local function sanitizeConfigName(name)
	name = tostring(name or ""):gsub("^%s+", ""):gsub("%s+$", "")
	name = name:gsub("[\\/:*?\"<>|]", "_")
	if name == "" then
		name = tostring(os.time())
	end
	return name
end

local function configPath(name)
	name = sanitizeConfigName(name)
	return CONFIG_FOLDER .. "/" .. name .. ".json"
end

local function listConfigNames()
	if not ensureWorkspace() then return {} end

	local names = {}
	for _, path in ipairs(listfiles(CONFIG_FOLDER)) do
		local fileName = path:match("[^/\\]+$")
		if fileName and fileName:sub(-5) == ".json" then
			table.insert(names, fileName:sub(1, -6))
		end
	end

	table.sort(names, function(a, b)
		local na, nb = tonumber(a), tonumber(b)
		if na and nb then return na < nb end
		return a < b
	end)

	return names
end

local function createConfig(name)
	if not ensureWorkspace() then return false end

	name = sanitizeConfigName(name)
	local path = configPath(name)

	if not isfile(path) then
		writefile(path, safeEncode(Config))
	end

	Config.SelectedConfig = name
	Config.LastConfigName = name
	saveIndexConfig()
	return true
end

local function saveSelectedConfig()
	if not ensureWorkspace() then return false end

	local name = Config.SelectedConfig
	if name == "" then
		name = sanitizeConfigName(Config.LastConfigName)
		Config.SelectedConfig = name
	end

	writefile(configPath(name), safeEncode(Config))
	saveIndexConfig()
	return true
end

local function loadSelectedConfig()
	if not ensureWorkspace() then return false end
	local name = Config.SelectedConfig
	if name == "" then return false end

	local path = configPath(name)
	if not isfile(path) then return false end

	local data = safeDecode(readfile(path))
	if not data then return false end

	applyTableToConfig(data)
	Config.SelectedConfig = name
	saveIndexConfig()
	return true
end

local function deleteSelectedConfig()
	if not ensureWorkspace() then return false end
	local name = Config.SelectedConfig
	if name == "" then return false end

	local path = configPath(name)
	if isfile(path) and delfile then
		delfile(path)
	elseif isfile(path) and writefile then
		-- fallback nếu executor không có delfile: làm rỗng file để tránh lỗi
		writefile(path, "{}")
		warn("[PennyHub] Executor không có delfile, config đã được làm rỗng thay vì xóa hẳn.")
	else
		return false
	end

	Config.SelectedConfig = ""
	saveIndexConfig()
	return true
end

