		if cur:IsA("TextButton") or cur:IsA("ImageButton") then
			return cur
		end

		cur = cur.Parent
	end

	return nil
end

local function findDrinkClickTarget(drinkName)
	local pg = player:FindFirstChild("PlayerGui")
	if not pg then return nil end

	local wanted = tostring(drinkName or ""):lower()

	-- Ưu tiên tìm text đúng tên nước trong UI shop.
	for _, v in ipairs(pg:GetDescendants()) do
		if v:IsA("GuiObject") and isGuiReallyVisible(v) then
			local txt = getTextOfGui(v):lower()

			if txt == wanted or txt:find(wanted, 1, true) then
				local btn = findClickableAncestor(v)
				if btn then
					return btn
				end

				-- Nếu text không nằm trong Button, click ngay vào chính TextLabel.
				return v
			end
		end
	end

	-- Fallback: tìm object có Name chứa tên nước.
	for _, v in ipairs(pg:GetDescendants()) do
		if v:IsA("GuiObject") and isGuiReallyVisible(v) then
			local nm = tostring(v.Name or ""):lower()

			if nm:find(wanted, 1, true) then
				local btn = findClickableAncestor(v)
				return btn or v
			end
		end
	end

	return nil
end

local function clickGuiObject(obj)
	if not obj or not obj:IsA("GuiObject") then return false end

	local clicked = false

	-- Nếu là GuiButton thì bắn signal trước.
	if obj:IsA("TextButton") or obj:IsA("ImageButton") then
		if firesignal then
			pcall(function()
				firesignal(obj.MouseButton1Click)
				clicked = true
			end)

			pcall(function()
				firesignal(obj.Activated)
				clicked = true
			end)
		end

		if getconnections then
			pcall(function()
				for _, c in ipairs(getconnections(obj.MouseButton1Click)) do
					c:Fire()
					clicked = true
				end
			end)

			pcall(function()
				for _, c in ipairs(getconnections(obj.Activated)) do
					c:Fire()
					clicked = true
				end
			end)
		end
	end

	-- Click chuột thật vào giữa object. Cách này hợp với UI shop dạng ImageLabel/TextLabel không có Button ancestor.
	local pos = obj.AbsolutePosition
	local size = obj.AbsoluteSize
	local x = pos.X + size.X / 2
	local y = pos.Y + size.Y / 2

	pcall(function()
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
		task.wait(0.03)
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
		clicked = true
	end)

	return clicked
end

local function clickDrinkUI(drinkName)
	local target = findDrinkClickTarget(drinkName)

	if not target then
		warn("[PennyHub] Không tìm thấy UI để click:", drinkName)
		return false
	end

	print("[PennyHub] Click drink UI:", drinkName, target:GetFullName())
	return clickGuiObject(target)
end

local function buyDrinkByClick(drinkName, amount, token)
	amount = math.floor(tonumber(amount) or 0)
	if amount <= 0 then return 0 end

	local bought = 0

	for i = 1, amount do
		if not Config.AutoBuyDrinkAmount then break end
		if not isCharacterReady() then break end
		if token and token ~= actionToken then break end

		-- UI shop sẽ tự tắt sau mỗi lần mua, nên phải mở lại trước từng lần click.
		openDrinkMerchant()
		task.wait(0.65)

		local ok = clickDrinkUI(drinkName)

		if ok then
			bought += 1
		else
			warn("[PennyHub] Click mua nước thất bại:", drinkName)
			break
		end

		task.wait(getBuyDrinkDelay())
	end

	return bought
