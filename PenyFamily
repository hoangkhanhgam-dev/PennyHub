			hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
		end
	end

	if hum and needReset then
		hum.PlatformStand = false
		hum.Sit = false
		hum.AutoRotate = true
		hum:ChangeState(Enum.HumanoidStateType.GettingUp)

		task.delay(0.15, function()
			if hum and hum.Parent then
				hum.PlatformStand = false
				hum.Sit = false
				hum.AutoRotate = true
				hum:ChangeState(Enum.HumanoidStateType.Running)
			end
		end)
	end

	floatActive = false
end


--// DROP PIN + NOCLIP
-- Giữ nhân vật đứng yên đúng điểm drop, hạn chế bị player khác đẩy ra chỗ quái.
local dropPinConn = nil
local dropNoClipBackup = {}

local function setDropNoClip(enabled)
	local char = player.Character
	if not char then return end

	for _, part in ipairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			if enabled then
				if dropNoClipBackup[part] == nil then
					dropNoClipBackup[part] = part.CanCollide
				end
				part.CanCollide = false
			else
				if dropNoClipBackup[part] ~= nil then
					part.CanCollide = dropNoClipBackup[part]
				end
			end
		end
	end

	if not enabled then
		dropNoClipBackup = {}
	end
end

local function stopDropPin()
	if dropPinConn then
		dropPinConn:Disconnect()
		dropPinConn = nil
	end

	setDropNoClip(false)
end

local function startDropPin(pinPos, token)
	if not Config.DropPinEnabled then return end

	stopDropPin()

	local char, hrp, hum = getChar()
	if not char or not hrp or not hum then return end

	if Config.DropNoClip then
		setDropNoClip(true)
	end

	hum.PlatformStand = true
	hum.Sit = false
	hum.AutoRotate = false

	if floatBV then
		floatBV.Velocity = Vector3.new(0, 0, 0)
		floatBV.MaxForce = Vector3.new(1e9, 1e9, 1e9)
	end

	if floatBG then
		floatBG.CFrame = CFrame.new(pinPos)
	end

	dropPinConn = RunService.Heartbeat:Connect(function()
		if token ~= actionToken or not Config.AutoDropSam or not isCharacterReady() then
			stopDropPin()
			return
		end

		local c = player.Character
		local root = c and c:FindFirstChild("HumanoidRootPart")
		local humanoid = c and c:FindFirstChildOfClass("Humanoid")
		if not root or not humanoid then return end

		if Config.DropNoClip then
			setDropNoClip(true)
		end

		humanoid.PlatformStand = true
		humanoid.Sit = false
		humanoid.AutoRotate = false

		root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
		root.CFrame = CFrame.new(pinPos)

		if floatBV then
			floatBV.Velocity = Vector3.new(0, 0, 0)
		end

		if floatBG then
			floatBG.CFrame = root.CFrame
		end
	end)
end


local function stopFloatIfIdle()
	if Config.AutoGetAfkReward or Config.AutoDropSam then return end
	if floatActive or floatBV or floatBG then
		forceStopFloat()
	end
end

local function cancelCurrentAutoMove()
	actionToken += 1
	stopDropPin()
	if not Config.AutoGetAfkReward and not Config.AutoDropSam then
		actionBusy = false
		forceStopFloat()
	end
end

task.spawn(function()
	while gui.Parent do
		if not Config.AutoGetAfkReward and not Config.AutoDropSam then
			stopFloatIfIdle()
		else
			if not isCharacterReady() then
				stopDropPin()
				forceStopFloat()
				task.wait()
				continue
			end

			if floatBV then
				floatBV.Velocity = Vector3.new(0, 0, 0)
			end

			if floatBG and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
				floatBG.CFrame = player.Character.HumanoidRootPart.CFrame
			end
		end

		task.wait()
	end
end)

local function flyTo(pos, token)
	token = token or actionToken
	if not isCharacterReady() then
		forceStopFloat()
		return false
	end

	if not Config.AutoGetAfkReward and not Config.AutoDropSam then
		forceStopFloat()
		return false
	end

	if not startFloat() then return false end

	local char, hrp = getChar()
	local speed = tonumber(Config.FlySpeed) or 300

	local distance = (hrp.Position - pos).Magnitude
	local time = math.max(distance / speed, 0.05)

	local tween = TweenService:Create(
		hrp,
		TweenInfo.new(time, Enum.EasingStyle.Linear),
		{ CFrame = CFrame.new(pos) }
	)

	tween:Play()

	while tween.PlaybackState == Enum.PlaybackState.Playing do
		if token ~= actionToken or (not Config.AutoGetAfkReward and not Config.AutoDropSam) then
			tween:Cancel()
			forceStopFloat()
			return false
		end
		task.wait()
	end

	return true
end

local function getAfkNpc()
	return workspace:WaitForChild("Merchants"):WaitForChild("AFK_NPC")
end

local function getNpcPart(npc)
	if npc:IsA("BasePart") then return npc end
	return npc:FindFirstChild("HumanoidRootPart")
		or npc:FindFirstChild("Clickable")
		or npc.PrimaryPart
		or npc:FindFirstChildWhichIsA("BasePart", true)
end

local function openAfkNpc()
	local npc = getAfkNpc()

	local clickDetector = npc:FindFirstChildWhichIsA("ClickDetector", true)
	if clickDetector and fireclickdetector then
		fireclickdetector(clickDetector)
		print("[PennyHub] Opened AFK_NPC with ClickDetector")
		return true
	end

	local prompt = npc:FindFirstChildWhichIsA("ProximityPrompt", true)
	if prompt and fireproximityprompt then
		fireproximityprompt(prompt)
		print("[PennyHub] Opened AFK_NPC with ProximityPrompt")
		return true
	end

	warn("[PennyHub] Không mở được AFK_NPC: không thấy ClickDetector/ProximityPrompt hoặc executor không hỗ trợ fire.")
	return false
end

local function claimAfkReward()
	local npc = getAfkNpc()
	local remote = npc:WaitForChild("Clickable"):WaitForChild("Remote")
	remote:FireServer("Claim")
	print("[PennyHub] Claimed AFK Reward")
end

local function itemMatch(name, typeName)
	name = string.lower(tostring(name or ""))

	if typeName == "Compass" then
		return name == "compass"
	elseif typeName == "SilverCompass" then
		return name == "silver compass" or name == "silvercompass" or name:find("silver") ~= nil
	elseif typeName == "GoldenCompass" then
		return name == "golden compass" or name == "goldencompass" or name:find("golden") ~= nil
	end

	return false
end

local function getTools(typeName)
	local tools = {}

	local function scan(container)
		if not container then return end

		for _, v in ipairs(container:GetChildren()) do
			if v:IsA("Tool") and itemMatch(v.Name, typeName) then
				table.insert(tools, v)
			end
		end
	end

	scan(player:FindFirstChild("Backpack"))
	scan(player.Character)

	return tools
end

local function hasAnySamTool()
	return #getTools("Compass") > 0 or #getTools("SilverCompass") > 0 or #getTools("GoldenCompass") > 0
end

local function pressBackspace()
	for i = 1, 3 do
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Backspace, false, game)
		task.wait(0.02)
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Backspace, false, game)
		task.wait(0.02)
	end
end

local function dropTool(tool)
	if not isCharacterReady() then return end

	local char, hrp, hum = getChar()
	if not char or not hrp or not hum then return end

	if not tool or not tool.Parent then return end

	if tool.Parent ~= char then
		hum:EquipTool(tool)
		task.wait(0.08)
	end

	pressBackspace()
	task.wait(0.08)
end

local function dropAll(typeName, pos, token)
	token = token or actionToken
	if token ~= actionToken or not Config.AutoDropSam then return end

	local tools = getTools(typeName)
	if #tools == 0 then
		print("[PennyHub] Không có:", typeName)
		return
	end

	local offsetY = tonumber(Config.DropPinOffsetY) or 3
	local dropPos = pos + Vector3.new(0, offsetY, 0)

	print("[PennyHub] Dropping:", typeName)
	if not flyTo(dropPos, token) then return end

	-- Vừa tới điểm drop thì ghim cứng ở đúng vị trí này.
	-- Điều này giúp hạn chế bị nhiều tài khoản/player khác đẩy ra khỏi điểm drop.
	startDropPin(dropPos, token)

	while Config.AutoDropSam and token == actionToken do
		local current = getTools(typeName)
		if #current == 0 then
			print("[PennyHub] Đã drop hết:", typeName)
			break
		end

		for _, tool in ipairs(current) do
			if token ~= actionToken or not Config.AutoDropSam then break end

			-- Re-pin trước mỗi lần drop để không bị lệch vị trí do va chạm/player khác.
			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if hrp then
				hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
				hrp.CFrame = CFrame.new(dropPos)
			end

			dropTool(tool)
			task.wait(0.08)
		end

		task.wait(0.05)
	end

	stopDropPin()
end

local function doGetAfkRewardOnce(token)
	token = token or actionToken
	if token ~= actionToken or not Config.AutoGetAfkReward then return end
	if not isCharacterReady() then return end
	if not startFloat() then return end

	local npc = getAfkNpc()
	local npcPart = getNpcPart(npc)

	if npcPart then
		if not flyTo(npcPart.Position + Vector3.new(0, 4, 5), token) then return end
		if token ~= actionToken or not Config.AutoGetAfkReward then return end
		task.wait(0.2)

		local char, hrp = getChar()
		if not char or not hrp then return end
		hrp.CFrame = CFrame.lookAt(hrp.Position, npcPart.Position)
		if floatBG then floatBG.CFrame = hrp.CFrame end

		task.wait(0.3)
		if token ~= actionToken or not Config.AutoGetAfkReward then return end
		openAfkNpc()
		task.wait(0.4)
		if token ~= actionToken or not Config.AutoGetAfkReward then return end
		claimAfkReward()
	else
		warn("[PennyHub] Không tìm thấy part của AFK_NPC")
	end
end

local function doDropSamOnce(token)
	token = token or actionToken
	if token ~= actionToken or not Config.AutoDropSam then return end
	if not isCharacterReady() then return end

	if not hasAnySamTool() then
		print("[PennyHub] Không có Compass/Silver/Golden để drop.")
		return
	end

	if not startFloat() then return end
	dropAll("Compass", DROP_POSITIONS.Compass, token)
	dropAll("SilverCompass", DROP_POSITIONS.SilverCompass, token)
	dropAll("GoldenCompass", DROP_POSITIONS.GoldenCompass, token)
end

local function runGetAfkReward()
	if autoRewardRunning then return end
	autoRewardRunning = true

	task.spawn(function()
		while Config.AutoGetAfkReward do
			if not isCharacterReady() then
				forceStopFloat()
				task.wait(0.5)
				continue
			end

			local myToken = actionToken
			waitActionFree()

			local ok, err = pcall(function()
				doGetAfkRewardOnce(myToken)

				-- Nếu Auto Drop Sam đang bật, claim xong sẽ drop ngay trong cùng một lượt.
				-- Như vậy không còn lỗi 2 chỗ fly tranh nhau nữa.
				if Config.AutoDropSam then
					task.wait(0.5)
					doDropSamOnce(myToken)
				end
			end)

			releaseAction()

			if not ok then
				warn("[PennyHub] Auto Get AFK Reward error:", err)
			end

			task.wait(2)
		end

		autoRewardRunning = false
		stopFloatIfIdle()
	end)
end

local function runAutoDropSam()
	if autoDropRunning then return end
	autoDropRunning = true

	task.spawn(function()
		while Config.AutoDropSam do
			if not isCharacterReady() then
				forceStopFloat()
				task.wait(0.5)
				continue
			end

			local myToken = actionToken
			-- Nếu Auto Get AFK Reward cũng đang bật thì để Auto Get làm chủ luồng:
			-- Claim xong rồi mới drop, tránh bị kéo về NPC giữa lúc đang drop.
			if Config.AutoGetAfkReward then
				task.wait(1)
			else
				waitActionFree()

				local ok, err = pcall(function()
					doDropSamOnce(myToken)
				end)

				releaseAction()

				if not ok then
					warn("[PennyHub] Auto Drop Sam error:", err)
				end

				task.wait(1)
			end
		end

		autoDropRunning = false
		stopFloatIfIdle()
	end)
end


