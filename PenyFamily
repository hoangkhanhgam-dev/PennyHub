local function updateScrollCanvas(page, extra)
	if not page or not page:IsA("ScrollingFrame") then return end
	extra = extra or 50

	local maxY = 0
	for _, child in ipairs(page:GetChildren()) do
		if child:IsA("GuiObject") then
			local bottom = child.Position.Y.Offset + child.Size.Y.Offset
			if bottom > maxY then
				maxY = bottom
			end
		end
	end

	page.CanvasSize = UDim2.new(0, 0, 0, math.max(page.AbsoluteSize.Y + 1, maxY + extra))
end

