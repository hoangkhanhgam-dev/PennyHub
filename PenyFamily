-- Startup logic:
-- Không bật Auto Load => reset về config mặc định mỗi lần chạy script.
-- Chỉ đọc file index để biết AutoLoadConfig / SelectedConfig / LastConfigName.
-- Bật Auto Load => mới tự load config đã chọn.
do
	local startupData = nil
	if isfile and isfile(CONFIG_INDEX_FILE) then
		startupData = safeDecode(readfile(CONFIG_INDEX_FILE))
	end

	if startupData then
		Config.AutoLoadConfig = startupData.AutoLoadConfig == true
		Config.SelectedConfig = tostring(startupData.SelectedConfig or "")
		Config.LastConfigName = tostring(startupData.LastConfigName or "1")
	end

	if Config.AutoLoadConfig and Config.SelectedConfig ~= "" then
		-- Giữ lại Auto Load ON trước khi load file.
		-- Lý do: file config cũ có thể lưu AutoLoadConfig = false, khi load sẽ tự tắt chính nó.
		local autoName = Config.SelectedConfig
		loadSelectedConfig()
		Config.AutoLoadConfig = true
		Config.SelectedConfig = autoName
		Config.LastConfigName = autoName
		saveIndexConfig()
	else
		-- Không bật Auto Load => mỗi lần chạy script reset về mặc định.
		-- Vẫn giữ tên config gần nhất để tiện chọn lại, nhưng không tự bật gì cả.
		Config.AfkArenaAuto = false
		Config.AutoGetAfkReward = false
		Config.AutoDropSam = false
		Config.FlySpeed = tonumber(Config.FlySpeed) or 300
		Config.DropPinEnabled = Config.DropPinEnabled ~= false
		Config.DropNoClip = Config.DropNoClip ~= false
		Config.DropPinOffsetY = tonumber(Config.DropPinOffsetY) or 3
		Config.AutoSpawn = false
		Config.AutoSpawnRespawnDelay = tonumber(Config.AutoSpawnRespawnDelay) or 3.5
		Config.AutoSpawnUIStable = tonumber(Config.AutoSpawnUIStable) or 1
		Config.AutoSpawnScriptDelay = tonumber(Config.AutoSpawnScriptDelay) or 4
		Config.WebhookEnabled = false
		Config.WebhookURL = ""
		Config.DiscordID = ""
		Config.TagBeri = false
		Config.TagGem = false
		Config.TagCompass = false
		Config.TagSilverCompass = false
		Config.TagGoldenCompass = false
		Config.AutoLoadConfig = false
		saveIndexConfig()
	end
end

