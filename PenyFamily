--// AFK WEBHOOK LOGIC
local function parseNumber(s)
	if not s then return nil end
	return tonumber((s:gsub("[,%s]", "")))
end

local function ensureAfkPlace()
	if game.PlaceId == AFK_CONFIG.AFK_PLACE_ID then return true end
	pcall(function()
		TeleportService:Teleport(AFK_CONFIG.AFK_PLACE_ID, player)
	end)
	return false
end

local function sendWebhook(lines, ping)
	if not Config.WebhookEnabled then
		warn("[PennyHub] Webhook đang OFF.")
		return false
	end

	if not Config.WebhookURL or Config.WebhookURL == "" then
		warn("[PennyHub] Chưa nhập Discord Webhook URL.")
		return false
	end

	if not http_request then
		warn("[PennyHub] Không tìm thấy http_request/request.")
		return false
	end

	local content = ""
	local discordId = tostring(Config.DiscordID or ""):gsub("%D", "")

	if ping and discordId ~= "" then
		content = "<@" .. discordId .. ">\n"
	end

	local body = table.concat(lines, "\n")
	if AFK_CONFIG.USE_TXT_BOX then
		content = content .. "[AFK Reward] " .. player.Name .. "\n```txt\n" .. body .. "\n```"
	else
		content = content .. "[AFK Reward] " .. player.Name .. "\n" .. body
	end

	local payload = {
		username = AFK_CONFIG.USERNAME,
		content = content
	}

	if ping and discordId ~= "" then
		payload.allowed_mentions = {
			parse = {},
			users = { discordId }
		}
	else
		payload.allowed_mentions = {
			parse = {}
		}
	end

	local ok, result = pcall(function()
		return http_request({
			Url = Config.WebhookURL,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = HttpService:JSONEncode(payload)
		})
	end)

	if not ok then
		warn("[PennyHub] Webhook request lỗi:", result)
		return false
	end

	local code = result and (result.StatusCode or result.Status or result.status_code)
	if code and tonumber(code) and tonumber(code) >= 400 then
		warn("[PennyHub] Webhook HTTP lỗi:", code, result.Body or "")
		return false
	end

	print("[PennyHub] Webhook sent.")
	return true
end

local function scanRewards(afkUi)
	local v = {
		Beri = nil,
		Gem = nil,
		Compass = nil,
		SilverCompass = nil,
		GoldenCompass = nil
	}

	for _, d in ipairs(afkUi:GetDescendants()) do
		if d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox") then
			local txt = d.Text or ""

			local beri = txt:match("[Bb]eri%s*:%s*([%d,%.]+)")
			local gem = txt:match("[Gg]ems?%s*:%s*([%d,%.]+)")
			local silver = txt:match("[Ss]ilver%s*[Cc]ompass%s*:%s*([%d,%.]+)")
			local golden = txt:match("[Gg]olden%s*[Cc]ompass%s*:%s*([%d,%.]+)")
			local compass = txt:match("^%s*[Cc]ompass%s*:%s*([%d,%.]+)") or txt:match("[^%a][Cc]ompass%s*:%s*([%d,%.]+)")

			if beri then v.Beri = parseNumber(beri) end
			if gem then v.Gem = parseNumber(gem) end
			if compass then v.Compass = parseNumber(compass) end
			if silver then v.SilverCompass = parseNumber(silver) end
			if golden then v.GoldenCompass = parseNumber(golden) end
		end
	end

	return v
end

local function stopAfk()
	afkRunning = false
end

local function startAfk()
	if afkRunning then return end
	afkRunning = true

	task.spawn(function()
		local inAfk = ensureAfkPlace()
		if not inAfk then
			afkRunning = false
			return
		end

		local pg = player:FindFirstChildOfClass("PlayerGui") or player:WaitForChild("PlayerGui", 20)
		if not pg then afkRunning = false return end

		local afkUi = pg:FindFirstChild("AFK_UI") or pg:WaitForChild("AFK_UI", 20)
		if not afkUi then
			warn("[PennyHub] Không tìm thấy AFK_UI.")
			afkRunning = false
			return
		end

		while afkRunning do
			local v = scanRewards(afkUi)
			local old = {
				Beri = lastRewards.Beri,
				Gem = lastRewards.Gem,
				Compass = lastRewards.Compass,
				SilverCompass = lastRewards.SilverCompass,
				GoldenCompass = lastRewards.GoldenCompass
			}

			local changed = {}
			local shouldPing = false

			local function check(key, display, tagKey)
				if v[key] and v[key] > lastRewards[key] then
					lastRewards[key] = v[key]
					local gain = lastRewards[key] - old[key]
					table.insert(changed, ("%s: %d -> %d (+%d)"):format(display, old[key], lastRewards[key], gain))
					if Config[tagKey] then
						shouldPing = true
					end
				end
			end

			check("Beri", "Beri", "TagBeri")
			check("Gem", "Gem", "TagGem")
			check("Compass", "Compass", "TagCompass")
			check("SilverCompass", "Silver Compass", "TagSilverCompass")
			check("GoldenCompass", "Golden Compass", "TagGoldenCompass")

			if #changed > 0 and (os.time() - lastSentTime >= AFK_CONFIG.COOLDOWN) then
				lastSentTime = os.time()
				sendWebhook(changed, shouldPing)
			end

			task.wait(1)
		end
	end)
end


