local function flyTo(pos, token)
	token = token or actionToken
	if not isCharacterReady() then
		forceStopFloat()
		return false
	end

	if not Config.AutoGetAfkReward and not Config.AutoDropSam and not Config.AutoDropCompassAmount and not Config.AutoDropDrinkAmount and not Config.AutoBuyDrinkAmount and not Config.AutoUseDrinkAmount and not Config.AutoChangeNoAfkRewards and not Config.AutoBuyDrinkAmount then
		forceStopFloat()
		return false
	end

	if not startFloat() then return false end

	local char, hrp = getChar()
	local speed = tonumber(Config.FlySpeed) or 300

	local distance = (hrp.Position - pos).Magnitude
	local time = math.max(distance / speed, 0.05)

	local tween = TweenService:Create(
		hrp,
		TweenInfo.new(time, Enum.EasingStyle.Linear),
		{ CFrame = CFrame.new(pos) }
	)

	tween:Play()

	while tween.PlaybackState == Enum.PlaybackState.Playing do
		if token ~= actionToken or (not Config.AutoGetAfkReward and not Config.AutoDropSam and not Config.AutoDropCompassAmount and not Config.AutoDropDrinkAmount and not Config.AutoBuyDrinkAmount and not Config.AutoUseDrinkAmount and not Config.AutoChangeNoAfkRewards) then
			tween:Cancel()
			forceStopFloat()
			return false
		end
		task.wait()
	end

	return true
end

