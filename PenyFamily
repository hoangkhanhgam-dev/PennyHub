--// CHARACTER READY GUARD
-- Các auto khác chỉ được chạy khi nhân vật đã spawn thật sự và đã qua delay ổn định.
-- Auto Spawn vẫn được phép chạy riêng để đưa nhân vật vào game.
local characterReadyAt = 0

local function getAutoSpawnScriptDelay()
	return math.clamp(tonumber(Config.AutoSpawnScriptDelay) or 4, 0, 15)
end

local function markCharacterNotReady()
	characterReadyAt = math.huge
end

local function markCharacterReadyAfterDelay()
	local char = player.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum and hum.Health > 0 then
		characterReadyAt = tick() + getAutoSpawnScriptDelay()
	else
		characterReadyAt = math.huge
	end
end

local function isCharacterReady()
	local char = player.Character
	if not char then return false end

	local hum = char:FindFirstChildOfClass("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")

	if not hum or not hrp then return false end
	if hum.Health <= 0 then return false end
	if tick() < characterReadyAt then return false end

	return true
end

local function waitUntilCharacterReady()
	while gui.Parent and not isCharacterReady() do
		task.wait(0.2)
	end

	return isCharacterReady()
end

local function getChar()
	if not waitUntilCharacterReady() then
		return nil, nil, nil
	end

	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")

	return char, hrp, hum
end

local guardedCharacters = {}
local function hookCharacterReadyGuard(char)
	if not char or guardedCharacters[char] then return end
	guardedCharacters[char] = true
	markCharacterNotReady()

	task.spawn(function()
		local hum = char:WaitForChild("Humanoid", 10)
		local hrp = char:WaitForChild("HumanoidRootPart", 10)
		if hum and hrp and hum.Health > 0 then
			markCharacterReadyAfterDelay()
		end

		if hum then
			hum.Died:Connect(function()
				markCharacterNotReady()
			end)
		end
	end)
end

if player.Character then
	hookCharacterReadyGuard(player.Character)
end

player.CharacterAdded:Connect(function(char)
	hookCharacterReadyGuard(char)
end)

