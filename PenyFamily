local function findSpawnButton()
	local pg = player:FindFirstChild("PlayerGui")
	if not pg then return nil end

	for _, v in ipairs(pg:GetDescendants()) do
		if v:IsA("TextButton") and v.Text == "Spawn" and v.Visible then
			return v
		end
	end

	return nil
end

local function isLoadFrameVisible()
	local pg = player:FindFirstChild("PlayerGui")
	if not pg then return false end

	local load = pg:FindFirstChild("Load")
	local frame = load and load:FindFirstChild("Frame")

	return frame and frame.Visible == true
end

local function hideSpawnUI()
	local pg = player:FindFirstChild("PlayerGui")
	if not pg then return end

	local load = pg:FindFirstChild("Load")
	if load and load:FindFirstChild("Frame") then
		load.Frame.Visible = false
	end
end

local function fixAfterAutoSpawn()
	task.spawn(function()
		local char
		local hum

		for i = 1, 100 do
			char = player.Character
			hum = char and char:FindFirstChildOfClass("Humanoid")

			if char and hum and hum.Health > 0 then
				break
			end

			task.wait(0.1)
		end

		if not hum then return end

		markCharacterReadyAfterDelay()

		for i = 1, 120 do
			hideSpawnUI()

			workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
			workspace.CurrentCamera.CameraSubject = hum

			task.wait(0.05)
		end
	end)
end

local function clickAutoSpawnButton(btn)
	if not btn then return false end

	if firesignal then
		firesignal(btn.MouseButton1Click)
		fixAfterAutoSpawn()
		return true
	end

	if getconnections then
		for _, c in ipairs(getconnections(btn.MouseButton1Click)) do
			c:Fire()
		end
		fixAfterAutoSpawn()
		return true
	end

	warn("[PennyHub] Executor không hỗ trợ firesignal/getconnections cho Auto Spawn.")
	return false
end

local function unlockAutoSpawnWhenUIReady()
	task.spawn(function()
		autoSpawnClickedLock = true

		task.wait(getAutoSpawnRespawnDelay())

		while Config.AutoSpawn and (findSpawnButton() == nil or not isLoadFrameVisible()) do
			task.wait(0.2)
		end

		if not Config.AutoSpawn then return end

		task.wait(getAutoSpawnUIStable())
		autoSpawnClickedLock = false
	end)
end

local function hookAutoSpawnDeath(char)
	if not char or autoSpawnHookedChars[char] then return end
	autoSpawnHookedChars[char] = true

	task.spawn(function()
		local hum = char:WaitForChild("Humanoid", 10)
		if hum then
			hum.Died:Connect(function()
				if Config.AutoSpawn then
					unlockAutoSpawnWhenUIReady()
				end
			end)
		end
	end)
end

local function runAutoSpawn()
	if autoSpawnRunning then return end
	autoSpawnRunning = true
	autoSpawnClickedLock = true

	if player.Character then
		hookAutoSpawnDeath(player.Character)
	end

	task.delay(2, function()
		if Config.AutoSpawn then
			autoSpawnClickedLock = false
		end
	end)

	task.spawn(function()
		while Config.AutoSpawn do
			task.wait(tonumber(CHECK_DELAY) or 0.5)

			local btn = findSpawnButton()
			local loadVisible = isLoadFrameVisible()

			if btn and loadVisible and not autoSpawnClickedLock then
				autoSpawnClickedLock = true

				local ok = clickAutoSpawnButton(btn)
				if not ok then
					autoSpawnClickedLock = false
				end
			end
		end

		autoSpawnRunning = false
		autoSpawnClickedLock = true
	end)
end

