button(configCard, "Load Selected", 15, 400, 85, 32, function()
	local keepAutoLoad = Config.AutoLoadConfig
	local keepSelected = Config.SelectedConfig

	if loadSelectedConfig() then
		-- Nếu trước khi load đang bật Auto Load, không cho file config tự tắt nó.
		if keepAutoLoad then
			Config.AutoLoadConfig = true
			Config.SelectedConfig = keepSelected
			Config.LastConfigName = keepSelected
			saveIndexConfig()
		end

		refreshAll()
		refreshConfigList()
		refreshSelectedLabel()

		-- Ưu tiên Auto Wood Rod Quest khi load config.
		-- Nếu đang bật, nó chạy trước; các auto bay/drop sẽ tự tạm nghỉ cho tới khi Wood Rod hoàn tất.
		if Config.AutoWoodRodQuest then
			cancelCurrentAutoMove()
			runAutoWoodRodQuest()
		end

		if Config.AfkArenaAuto and not Config.AutoWoodRodQuest then
			startAfk()
		elseif not Config.AfkArenaAuto then
			stopAfk()
		end

		if Config.AutoGetAfkReward and not Config.AutoWoodRodQuest then
			runGetAfkReward()
		end

		if Config.AutoDropSam and not Config.AutoWoodRodQuest then
			runAutoDropSam()
		end

		if Config.AutoChangeNoAfkRewards and not Config.AutoWoodRodQuest then
			runAutoChangeNoAfkRewards()
		end

		if Config.AutoSpawn then
			runAutoSpawn()
		end

		if Config.AutoGemGiftBox then
			runAutoGemGiftBox()
		end

		if Config.AutoBeriGiftBox then
			runAutoBeriGiftBox()
		end
	end
end)

