-- Copy current config to clipboard
local function prettyJSON(str)
	local indent = 0
	local inString = false
	local escape = false
	local out = {}

	for i = 1, #str do
		local c = str:sub(i, i)

		if inString then
			table.insert(out, c)
			if escape then
				escape = false
			elseif c == "\\" then
				escape = true
			elseif c == '"' then
				inString = false
			end
		else
			if c == '"' then
				inString = true
				table.insert(out, c)
			elseif c == "{" or c == "[" then
				indent = indent + 1
				table.insert(out, c .. "\n" .. string.rep("  ", indent))
			elseif c == "}" or c == "]" then
				indent = math.max(indent - 1, 0)
				table.insert(out, "\n" .. string.rep("  ", indent) .. c)
			elseif c == "," then
				table.insert(out, c .. "\n" .. string.rep("  ", indent))
			elseif c == ":" then
				table.insert(out, ": ")
			else
				table.insert(out, c)
			end
		end
	end

	return table.concat(out)
end

local function copyCurrentConfig()
	local ok, data = pcall(function()
		return HttpService:JSONEncode(Config)
	end)

	if not ok then
		warn("[PennyHub] Encode config lỗi")
		return false
	end

	if setclipboard then
		setclipboard(prettyJSON(data))
		print("[PennyHub] Đã copy config đẹp vào clipboard")
		return true
	end

	warn("[PennyHub] Executor không hỗ trợ setclipboard")
	return false
end

