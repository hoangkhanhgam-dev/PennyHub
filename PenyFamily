end

local function findWoodRodTool()
	local char = player.Character
	local backpack = player:FindFirstChild("Backpack")
	return (char and char:FindFirstChild("Wood Rod")) or (backpack and backpack:FindFirstChild("Wood Rod"))
end

local function equipAnyTool(tool)
	if not tool then return false end
	local char, hrp, hum = getChar()
	if not char or not hum then return false end
	if tool.Parent ~= char then
		hum:EquipTool(tool)
		task.wait(0.25)
	end
	return true
end

local function tryUpdateWoodRod()
	pcall(function()
		game:GetService("ReplicatedStorage")
			:WaitForChild("Connections")
			:WaitForChild("UpdateWeapon")
			:FireServer("Wood Rod")
	end)

	task.wait(0.5)

	local rod = findWoodRodTool()
	if rod then
		print("[PennyHub] Wood Rod found. Equipping and stopping Auto Wood Rod Quest.")
		equipAnyTool(rod)
		Config.AutoWoodRodQuest = false
		saveIndexConfig()
		if refreshers.AutoWoodRodQuest then
			pcall(refreshers.AutoWoodRodQuest)
		end

		-- Wood Rod xong thì trả quyền cho các auto khác nếu chúng vẫn đang bật.
		task.defer(function()
			if Config.AfkArenaAuto then
				startAfk()
			end
			if Config.AutoGetAfkReward then
				runGetAfkReward()
			end
			if Config.AutoDropSam then
				runAutoDropSam()
			end
		end)

		return true
	end

	return false
end

local function getPackageTool()
	local char = player.Character
	local backpack = player:FindFirstChild("Backpack")
	return (char and char:FindFirstChild("Package")) or (backpack and backpack:FindFirstChild("Package"))
end

local function equipPackageTool()
	local pkg = getPackageTool()
	if not pkg then return nil end
	equipAnyTool(pkg)
	return getPackageTool()
end

local function woodRodTp(pos)
	local char, hrp = getChar()
	if not char or not hrp then return false end
	hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
	hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
	hrp.CFrame = CFrame.new(pos)
	task.wait(getWoodRodTPDelay())
	return true
end

local function getWoodRodNpcPart(npc)
	if not npc then return nil end
	if npc:IsA("BasePart") then return npc end
	return npc:FindFirstChild("HumanoidRootPart")
		or npc:FindFirstChild("Head")
		or npc.PrimaryPart
		or npc:FindFirstChildWhichIsA("BasePart", true)
end

local function getWoodRodTouchPos(part)
	local char, hrp = getChar()
	if not hrp or not part then return nil end

	local dir = hrp.Position - part.Position
	if dir.Magnitude < 0.1 then
		dir = part.CFrame.LookVector
	else
		dir = dir.Unit
	end

	return part.Position + dir * 0.8
end

local function pinWoodRodToNpc(part, duration)
	local char, hrp = getChar()
	if not hrp or not part then return end

	local start = tick()
	while Config.AutoWoodRodQuest and tick() - start < duration do
		local pos = getWoodRodTouchPos(part)
		if not pos then break end
		hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
		hrp.CFrame = CFrame.lookAt(pos, part.Position)
		task.wait()
	end
end

local function getWoodRodQuest()
	local npc = workspace:WaitForChild("Merchants"):WaitForChild("QuestFishMerchant")
	local part = getWoodRodNpcPart(npc)
	if part then
		woodRodTp(part.Position + Vector3.new(0, 3, 5))
	end

	local remote = npc:WaitForChild("Clickable"):WaitForChild("Retum")
	remote:FireServer("Package")
	task.wait(0.3)
	remote:FireServer("Close")
end

local function tryDeliverWoodRodPackageToNpc(npc)
	local part = getWoodRodNpcPart(npc)
	if not part then return false end

	print("[PennyHub] Auto Wood Rod Quest trying NPC:", npc.Name)

	local touchPos = getWoodRodTouchPos(part)
	if not touchPos then return false end
	woodRodTp(touchPos)
	pinWoodRodToNpc(part, 0.5)

	for i = 1, 5 do
		if not Config.AutoWoodRodQuest then return false end

		local pkg = equipPackageTool()
		if not pkg then
			print("[PennyHub] Package delivered at:", npc.Name)
			woodRodCachedNpcName = npc.Name
			return true
		end

		pcall(function()
			pkg:Activate()
		end)

		pinWoodRodToNpc(part, 0.15)
		task.wait(0.15)

		if not getPackageTool() then
			print("[PennyHub] Package delivered at:", npc.Name)
			woodRodCachedNpcName = npc.Name
			return true
		end
	end

	return false
end

local function getWoodRodNpcList()
	local merchants = workspace:FindFirstChild("Merchants")
	if not merchants then return {} end

	local list = {}

	if woodRodCachedNpcName then
		local cached = merchants:FindFirstChild(woodRodCachedNpcName)
		if cached and cached:IsA("Model") then
			table.insert(list, cached)
		end
	end

	for _, npc in ipairs(merchants:GetChildren()) do
		if npc:IsA("Model") and npc.Name ~= "QuestFishMerchant" and npc.Name ~= woodRodCachedNpcName then
			table.insert(list, npc)
		end
	end

	return list
end

local function deliverWoodRodPackageByScan()
	for _, npc in ipairs(getWoodRodNpcList()) do
		if not Config.AutoWoodRodQuest then return false end
		if not getPackageTool() then return true end
		if tryDeliverWoodRodPackageToNpc(npc) then
			return true
		end
		task.wait(0.1)
	end

	woodRodCachedNpcName = nil
	return not getPackageTool()
end

local function runAutoWoodRodQuest()
	if autoWoodRodQuestRunning then return end
	autoWoodRodQuestRunning = true

	task.spawn(function()
		while Config.AutoWoodRodQuest do
			local ok, err = pcall(function()
				if not isCharacterReady() then
					task.wait(0.5)
					return
				end

				if tryUpdateWoodRod() then
					return
				end

				if not getPackageTool() then
					getWoodRodQuest()
				else
					deliverWoodRodPackageByScan()
				end
			end)

			if not ok then
				warn("[PennyHub] Auto Wood Rod Quest error:", err)
			end

			task.wait(1)
		end

		autoWoodRodQuestRunning = false
	end)
end


