local function startFloat()
	if not isCharacterReady() then return false end

	local char, hrp, hum = getChar()
	if not char or not hrp or not hum then return false end

	floatActive = true
	hum.PlatformStand = true
	hum.Sit = false
	hum.AutoRotate = true

