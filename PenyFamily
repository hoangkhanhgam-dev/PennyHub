			return v
		end
	end

	return nil
end

local function isLoadFrameVisible()
	local pg = player:FindFirstChild("PlayerGui")
	if not pg then return false end

	local load = pg:FindFirstChild("Load")
	local frame = load and load:FindFirstChild("Frame")

	return frame and frame.Visible == true
end

