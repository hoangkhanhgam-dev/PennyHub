local function isGuiReallyVisible(obj)
	if not obj or not obj:IsA("GuiObject") then return false end
	if not obj.Visible then return false end

	local cur = obj.Parent
	while cur do
		if cur:IsA("GuiObject") and not cur.Visible then
			return false
		end
		cur = cur.Parent
	end

	return true
end

